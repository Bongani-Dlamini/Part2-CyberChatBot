<Window x:Class="Part2_CyberChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot - Cybersecurity Awareness Chatbot"
        Height="700" Width="900"
        MinHeight="600" MinWidth="750"
        Background="#2B2B2B"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1E1E1E"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,10">
            <TextBlock x:Name="AsciiArtBlock"
                       FontFamily="Courier New"
                       FontSize="10"
                       Foreground="#00FF88"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"/>
        </Border>

        <Border Grid.Row="1"
                x:Name="NamePanel"
                Background="#3C3C3C"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="What is your name? "
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>
                <TextBox x:Name="txtName"
                         Width="200"
                         Height="32"
                         FontSize="13"
                         Background="#555555"
                         Foreground="White"
                         CaretBrush="White"
                         BorderBrush="Gray"
                         BorderThickness="1"
                         Padding="5,4"
                         Margin="8,0"
                         KeyDown="txtName_KeyDown"/>
                <Button x:Name="btnStartChat"
                        Content="Start Chat"
                        Click="StartChat"
                        Background="#00CC66"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        Padding="12,6"
                        Cursor="Hand"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#1E1E1E"
                CornerRadius="6"
                Padding="5"
                Margin="0,0,0,10">
            <RichTextBox x:Name="txtDisplay"
                         IsReadOnly="True"
                         Background="#1E1E1E"
                         Foreground="White"
                         FontSize="13"
                         FontFamily="Segoe UI"
                         BorderThickness="0"
                         Padding="8"
                         VerticalScrollBarVisibility="Auto"/>
        </Border>

        <WrapPanel Grid.Row="3"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center">

            <Button x:Name="btnPasswords"
                    Content="Passwords"
                    Click="QuickTopic_Click"
                    Tag="passwords"
                    Background="#555555"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="10,5"
                    Margin="4"
                    FontSize="12"
                    Cursor="Hand"/>

            <Button x:Name="btnPhishing"
                    Content="Phishing"
                    Click="QuickTopic_Click"
                    Tag="phishing"
                    Background="#555555"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="10,5"
                    Margin="4"
                    FontSize="12"
                    Cursor="Hand"/>

            <Button x:Name="btnPrivacy"
                    Content="Privacy"
                    Click="QuickTopic_Click"
                    Tag="privacy"
                    Background="#555555"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="10,5"
                    Margin="4"
                    FontSize="12"
                    Cursor="Hand"/>

            <Button x:Name="btnScams"
                    Content="Scams"
                    Click="QuickTopic_Click"
                    Tag="online scams"
                    Background="#555555"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="10,5"
                    Margin="4"
                    FontSize="12"
                    Cursor="Hand"/>

            <Button x:Name="btnMalware"
                    Content="Malware"
                    Click="QuickTopic_Click"
                    Tag="malware"
                    Background="#555555"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="10,5"
                    Margin="4"
                    FontSize="12"
                    Cursor="Hand"/>

            <Button x:Name="btnTopics"
                    Content="All Topics"
                    Click="QuickTopic_Click"
                    Tag="topics"
                    Background="#555555"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="10,5"
                    Margin="4"
                    FontSize="12"
                    Cursor="Hand"/>
        </WrapPanel>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtUserInput"
                     Grid.Column="0"
                     Height="40"
                     FontSize="13"
                     Background="#3C3C3C"
                     Foreground="White"
                     CaretBrush="White"
                     BorderBrush="Gray"
                     BorderThickness="1"
                     Padding="10,8"
                     IsEnabled="False"
                     KeyDown="txtUserInput_KeyDown"/>

            <Button x:Name="btnSend"
                    Grid.Column="1"
                    Content="Send"
                    Click="btnSend_Click"
                    IsEnabled="False"
                    Background="Black"
                    Foreground="ForestGreen"
                    FontWeight="Bold"
                    FontSize="13"
                    Width="80"
                    Height="40"
                    Margin="8,0,0,0"
                    Cursor="Hand"
                    BorderThickness="0"/>

            <Button x:Name="btnClear"
                    Grid.Column="2"
                    Content="Clear"
                    Click="btnClear_Click"
                    Background="#CC3333"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="13"
                    Width="80"
                    Height="40"
                    Margin="8,0,0,0"
                    Cursor="Hand"
                    BorderThickness="0"/>
        </Grid>
    </Grid>
</Window>
